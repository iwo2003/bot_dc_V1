# =============================================================================
# Discord — wymagane do uruchomienia bota
# =============================================================================

# Token bota z Discord Developer Portal → Twoja aplikacja → Bot → Reset Token
TOKEN=twoj_token_bota

# ID aplikacji (Application ID) z zakładki „General Information”
CLIENT_ID=id_aplikacji_discord

# ID serwera Discord, na którym bot rejestruje komendy slash (Guild ID)
# PPM na ikonę serwera → Kopiuj identyfikator serwera (włącz tryb deweloperski)
GUILD_ID=id_serwera_discord

# Cooldown komend w sekundach (domyślnie 3)
DEFAULT_COMMAND_COOLDOWN=3

# =============================================================================
# MySQL — opcjonalne (bot działa też bez bazy)
# =============================================================================
# Jeśli NIE ustawisz DB_HOST, bot uruchomi się normalnie, ale bez zapisu do MySQL.
# Gdy ustawisz DB_HOST, przy starcie bot sprawdzi połączenie (SELECT 1).

# Adres serwera MySQL (np. 127.0.0.1 lub IP serwera w sieci)
DB_HOST=127.0.0.1

# Port MySQL (domyślnie 3306)
DB_PORT=3306

# Użytkownik MySQL
DB_USER=root

# Hasło użytkownika (zostaw puste, jeśli brak hasła)
DB_PASSWORD=

# Nazwa bazy danych — musi już istnieć na serwerze MySQL, np.:
# CREATE DATABASE `bot_dc` CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DB_NAME=bot_dc

# =============================================================================
# API gier — opcjonalne (bez klucza dana gra zwróci komunikat w /stats)
# =============================================================================

# Riot Games — League of Legends + Valorant
# https://developer.riotgames.com/
RIOT_API_KEY=

# Steam — Counter-Strike 2
# https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Fortnite — fortnite-api.com (opcjonalnie, część endpointów wymaga klucza)
# https://fortnite-api.com/
FORTNITE_API_KEY=
